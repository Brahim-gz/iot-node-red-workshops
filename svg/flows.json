        "wires": []
    },
    {
        "id": "711c45f3e98f7161",
        "type": "ui_template",
        "z": "ca58b63b8d47f3fd",
        "group": "cb95bbf634231de9",
        "name": "SVG Ride",
        "order": 2,
        "width": "0",
        "height": "0",
        "format": "<div style=\"text-align:center\">\n  <svg width=\"300\" height=\"300\" viewBox=\"0 0 200 200\">\n\n    <!-- DEFINITIONS -->\n    <defs>\n      <!-- Glow -->\n      <radialGradient id=\"heatGradient\">\n        <stop offset=\"0%\" stop-color=\"yellow\" />\n        <stop offset=\"100%\" stop-color=\"red\" />\n      </radialGradient>\n\n      <!-- Blur filter -->\n      <filter id=\"blur\">\n        <feGaussianBlur stdDeviation=\"2\" />\n      </filter>\n    </defs>\n\n    <!-- ALERT PULSE -->\n    <circle id=\"alertRing\" cx=\"100\" cy=\"100\" r=\"90\" stroke=\"red\" stroke-width=\"2\" fill=\"none\" opacity=\"0\" />\n\n    <!-- WHEEL -->\n    <g id=\"wheel\">\n\n      <!-- Outer circle -->\n      <circle cx=\"100\" cy=\"100\" r=\"70\" stroke=\"black\" fill=\"none\" stroke-width=\"3\" />\n\n      <!-- SEATS -->\n      <g class=\"seat\" transform=\"rotate(0,100,100)\">\n        <circle cx=\"100\" cy=\"30\" r=\"8\" fill=\"blue\" />\n      </g>\n      <g class=\"seat\" transform=\"rotate(90,100,100)\">\n        <circle cx=\"100\" cy=\"30\" r=\"8\" fill=\"blue\" />\n      </g>\n      <g class=\"seat\" transform=\"rotate(180,100,100)\">\n        <circle cx=\"100\" cy=\"30\" r=\"8\" fill=\"blue\" />\n      </g>\n      <g class=\"seat\" transform=\"rotate(270,100,100)\">\n        <circle cx=\"100\" cy=\"30\" r=\"8\" fill=\"blue\" />\n      </g>\n\n    </g>\n\n    <!-- CORE -->\n    <circle id=\"core\" cx=\"100\" cy=\"100\" r=\"18\" fill=\"green\" />\n\n  </svg>\n</div>\n\n<style>\n  @keyframes pulse {\n    0% {\n      opacity: 0.1;\n      r: 70;\n    }\n\n    50% {\n      opacity: 0.8;\n      r: 90;\n    }\n\n    100% {\n      opacity: 0.1;\n      r: 70;\n    }\n  }\n</style>\n\n<script>\n  (function(scope) {\n\nlet angle = 0;\nlet velocity = 0;\nlet vibrationOffset = 0;\n\nfunction animate() {\n\n    const wheel = document.getElementById(\"wheel\");\n\n    // Apply vibration\n    let shakeX = (Math.random() - 0.5) * vibrationOffset;\n    let shakeY = (Math.random() - 0.5) * vibrationOffset;\n\n    wheel.setAttribute(\"transform\",\n        `translate(${shakeX},${shakeY}) rotate(${angle},100,100)`);\n\n    angle += velocity;\n\n    requestAnimationFrame(animate);\n}\n\nanimate();\n\nscope.$watch('msg', function(msg) {\n    if (!msg) return;\n\n    let speed = msg.payload.speed;\n    let temp = msg.payload.temperature;\n    let vib = msg.payload.vibration;\n    let status = msg.payload.status;\n\n    // inertia\n    velocity += (speed * 0.05 - velocity) * 0.1;\n\n    // heat glow\n    let core = document.getElementById(\"core\");\n    if (temp > 70) {\n        core.setAttribute(\"fill\", \"url(#heatGradient)\");\n    } else {\n        core.setAttribute(\"fill\", \"green\");\n    }\n\n    // vibration effect\n    vibrationOffset = vib;\n\n    // alert pulse\n    let ring = document.getElementById(\"alertRing\");\n    if (status === \"DANGER\") {\n        ring.style.animation = \"pulse 1s infinite\";\n    } else {\n        ring.style.animation = \"none\";\n        ring.setAttribute(\"opacity\", \"0\");\n    }\n\n});\n})(scope);\n</script>",
        "storeOutMessages": true,
        "fwdInMessages": true,
        "resendOnRefresh": false,
        "templateScope": "local",
        "className": "",
        "x": 1300,
        "y": 620,
        "wires": [
