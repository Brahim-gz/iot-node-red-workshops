    {
        "id": "7e22a9ea7fe3fd66",
        "type": "function",
        "z": "ca58b63b8d47f3fd",
        "name": "Simulate Sensors",
        "func": "let speed = flow.get('speed') || 50;\nlet running = flow.get('running') || false;\n\nmsg.payload = {\n    speed: running ? speed : 0,\n    load: Math.floor(Math.random()*20),\n    vibration: Math.random()*10,\n    temperature: 20 + Math.random()*80\n};\nreturn msg;",
        "outputs": 1,
        "x": 850,
        "y": 660,
        "wires": [
            [
                "e91cd12fe5c02a4e"
            ]
        ]
    },
    {
        "id": "e91cd12fe5c02a4e",
        "type": "function",
        "z": "ca58b63b8d47f3fd",
        "name": "Safety Logic",
        "func": "let p = msg.payload;\nlet status = \"SAFE\";\nlet color = \"green\";\n\nif (p.temperature > 80 || p.vibration > 7) {\n    status = \"DANGER\";\n    color = \"red\";\n} else if (p.temperature > 60 || p.vibration > 5) {\n    status = \"WARNING\";\n    color = \"orange\";\n}\n\nmsg.payload.status = status;\nmsg.payload.color = color;\nreturn msg;",
        "outputs": 1,
        "x": 1050,
        "y": 660,
        "wires": [
            [
                "03d316f897e88e6f",
                "711c45f3e98f7161"
            ]
        ]
    },
    {
        "id": "03d316f897e88e6f",
        "type": "ui_text",
        "z": "ca58b63b8d47f3fd",
        "group": "cb95bbf634231de9",
        "order": 1,
        "width": 6,
        "height": 1,
        "label": "Ride Status",
