        "name": "Format Results",
        "func": "if (msg.topic !== \"predictions\") return null;\n\nlet preds = msg.payload || [];\n\nmsg.payload = {\n    count: preds.length,\n    list: preds.map(p =>\n        `${p.class} (${Math.round(p.score * 100)}%)`\n    )\n};\n\nreturn msg;",
