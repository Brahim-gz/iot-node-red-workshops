    {
        "id": "4ecb6ee5c89ac237",
        "type": "ui_template",
        "z": "11e80a167cab761c",
        "group": "aaa2f5c7e2cb759f",
        "name": "Results",
        "order": 0,
        "width": 0,
        "height": 0,
        "format": "<style>\n    :host {\n        width: 100% !important;\n        height: 80vh !important;\n        display: block;\n    }\n</style>\n\n<div style=\"\nheight:80vh;\nwidth:100%;\npadding:15px;\nbackground:#111827;\ncolor:white;\nborder-radius:12px;\n\">\n\n    <h3>Results</h3>\n\n    <div>\n        Objects detected:\n        <span style=\"background:#22c55e;padding:5px 10px;border-radius:20px;\">\n{{msg.payload.count || 0}}\n</span>\n    </div>\n\n    <div ng-repeat=\"item in msg.payload.list\" style=\"margin-top:8px;padding:8px;background:#1f2937;border-radius:8px;\">\n        {{item}}\n    </div>\n\n</div>",
        "storeOutMessages": true,
